# Production Environment Variables
# Copy this to .env on your VPS and update with actual production values

# Server Configuration
NODE_ENV=production
PORT=5000
API_VERSION=v1

# PostgreSQL Database (Local on VPS)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghumo_phiro_db
DB_USER=ghumo_db_user
DB_PASSWORD=YOUR_PRODUCTION_DB_PASSWORD_HERE

# Database URL (URL-encode special characters in password: ! = %21, # = %23, @ = %40, etc.)
DATABASE_URL=postgresql://ghumo_db_user:YOUR_PRODUCTION_DB_PASSWORD_HERE@localhost:5432/ghumo_phiro_db

# JWT Authentication (Generate strong random strings for production)
JWT_SECRET=YOUR_PRODUCTION_JWT_SECRET_MIN_64_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=YOUR_PRODUCTION_REFRESH_SECRET_MIN_64_CHARS_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=30d

# Redis Cache (Local on VPS)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_IF_SET

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=djoqjwwid
CLOUDINARY_API_KEY=661467625611547
CLOUDINARY_API_SECRET=sFMTi9xtJnRihYvGGmcQ32nhubU

# CORS Configuration (Update with your domain)
CORS_ORIGIN=http://your-domain.com,https://your-domain.com,http://187.127.151.137

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
