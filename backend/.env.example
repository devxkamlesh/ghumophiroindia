# ============================================
# LOCALHOST DEVELOPMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values
# ============================================

# Server Configuration
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ============================================
# DATABASE OPTIONS (Choose One)
# ============================================

# Option A: Supabase (Recommended for Beginners)
# Get from: https://app.supabase.com → Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres

# Option B: Local PostgreSQL
DATABASE_URL=postgresql://ghumo_user:your_password@localhost:5432/ghumo_phiro_local

# Legacy format (not needed if using DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ghumo_phiro_local
# DB_USER=ghumo_user
# DB_PASSWORD=your_password

# ============================================
# JWT Authentication
# ============================================
# Generate strong random strings (min 32 chars)
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-random-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# REDIS CACHE (Optional)
# ============================================
# Comment out if not using Redis
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# CLOUDINARY (Image Upload)
# ============================================
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# CORS Configuration
# ============================================
# Frontend URL (localhost for development)
CORS_ORIGIN=http://localhost:3000

# ============================================
# FILE UPLOAD
# ============================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug

