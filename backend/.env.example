# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# PostgreSQL Database (Local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ghumo_phiro_db
DB_USER=ghumo_admin
DB_PASSWORD=your_secure_database_password_here

# Database URL (URL-encode special characters in password: ! = %21, # = %23, @ = %40, etc.)
DATABASE_URL=postgresql://ghumo_admin:your_secure_database_password_here@localhost:5432/ghumo_phiro_db

# JWT Authentication (Generate strong random strings)
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long_random_string_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars_long_random_string_here
JWT_REFRESH_EXPIRES_IN=30d

# Redis Cache (Local)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,http://187.127.151.137,http://187.127.151.137:3000,http://187.127.151.137:5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
