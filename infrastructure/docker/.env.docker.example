# Copy to `infrastructure/docker/.env` ON THE VPS and fill in real values.
# This file (the example) is safe to commit; the real `.env` must NOT be.

# --- Image tags (set by CI to the commit SHA; default to :latest) ---
BACKEND_IMAGE=ghcr.io/devxkamlesh/ghumo-backend:latest
FRONTEND_IMAGE=ghcr.io/devxkamlesh/ghumo-frontend:latest

# --- Postgres (container) ---
DB_NAME=ghumophiro
DB_USER=ghumo_user
DB_PASSWORD=change_me_strong

# --- Redis (container) — leave blank to run without a password (network-internal only) ---
REDIS_PASSWORD=

# --- Backend secrets (consumed via env_file) ---
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_different
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
FRONTEND_URL=https://ghumofiroindia.com
CORS_ORIGIN=https://ghumofiroindia.com

# --- Frontend public vars (build-time + runtime) ---
NEXT_PUBLIC_API_URL=https://ghumofiroindia.com/api/v1
NEXT_PUBLIC_APP_URL=https://ghumofiroindia.com
