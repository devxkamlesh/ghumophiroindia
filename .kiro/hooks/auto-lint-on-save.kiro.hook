{
  "enabled": true,
  "name": "Auto Lint on Save",
  "description": "Runs ESLint automatically when TypeScript files are saved",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/src/**/*.ts",
      "frontend/src/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "cd frontend && npm run lint",
    "timeout": 30
  }
}