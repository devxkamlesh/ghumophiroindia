# Database - Supabase Connection Pooling (for production/serverless)
# Get these from: Supabase Dashboard > Project Settings > Database > Connection Pooling
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Database Connection (for migrations)
# Get these from: Supabase Dashboard > Project Settings > Database > Connection String
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# Auth
AUTH_SECRET="your-32-char-random-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend or other provider)
RESEND_API_KEY=""
EMAIL_FROM="noreply@ghumophiroindia.com"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WHATSAPP_NUMBER="+919876543210"

# Optional: Analytics
NEXT_PUBLIC_GA_ID=""

# Optional: Image Upload (Cloudinary, S3, etc.)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
